# ==============================================================
# VaultRelayClientSide — Centralized .gitignore
# ==============================================================

# ─── Rust / WASM (signal-wasm-bridge) ─────────────────────────
signal-wasm-bridge/target/
signal-wasm-bridge/pkg/

# ─── Rust / libsignal (vendored dependency) ───────────────────
# libsignal has its own .gitignore — these are extra safety nets
libsignal/target/

# ─── Node / Frontend (vault-relay-frontend) ───────────────────
vault-relay-frontend/node_modules/
vault-relay-frontend/dist/
vault-relay-frontend/dist-ssr/
vault-relay-frontend/.vite/
vault-relay-frontend/*.local

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Environment / Secrets ───────────────────────────────────
.env
.env.*
!.env.example

# ─── OS files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── Editor / IDE ────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
\#*\#
.\#*

# ─── Visual Studio ──────────────────────────────────────────
*.code-workspace

# ─── Coverage / Test output ──────────────────────────────────
coverage/
*.lcov
.nyc_output/
